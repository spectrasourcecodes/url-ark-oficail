{
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/server.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/client/dist/$1" },
    { "src": "/.*", "dest": "/client/dist/index.html" }
  ]
}